<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="?attr/colorError"
    app:cardElevation="8dp"
    app:strokeColor="?attr/colorError">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvErrorFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MainActivity.kt:45"
            android:textStyle="bold"
            android:textColor="?attr/colorOnError"/>

        <TextView
            android:id="@+id/tvErrorMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Unresolved reference: buildLayout"
            android:textColor="?attr/colorOnError"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCopyError"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="@string/btn_copy_error"
            android:textColor="?attr/colorOnError"
            app:iconTint="?attr/colorOnError"
            app:icon="@drawable/ic_copy"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
